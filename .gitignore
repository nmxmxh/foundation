# macOS
.DS_Store
**/.DS_Store

# Dependencies
**/node_modules/
.pnpm-store/

# Build outputs
**/dist/
**/build/
**/target/
**/*.wasm
*.tsbuildinfo
*.gz
*.br

# Go
**/*.exe
**/*.dll
**/*.so
**/*.dylib
**/*.a
**/*.o
**/*.prof
**/coverage.txt
**/.gocache/
**/.cache/

# Test outputs
**/coverage/
**/*.cover
**/*.out
**/test-results/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
**/logs/
# benchmark evidence logs referenced by the ledger stay tracked despite *.log;
# `git add -f` new artifacts when the ledger gains rows (check-benchmark-evidence)

# Temporary files
**/tmp/
**/.tmp/

# Environment (should not be in foundation but just in case)
.env
.env.*
# scaffold source shipped to projects (see templates/scaffold.manifest.tsv) — placeholders only
!templates/.env.example

# Agent memory + conductor (in-house / experimental for now — not shipped or scaffolded yet)
agent_memory/

# TLC model-checker scratch output (must never land in docs/ — docs/ propagates to apps)
**/states/
**/*_TTrace_*.tla
.tla-scratch/
