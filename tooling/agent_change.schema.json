{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Foundation agent change model",
  "type": "object",
  "required": ["schemaVersion", "objective", "feature", "risk", "commands", "projection", "worker", "offline", "realtime", "conflictPolicy", "fallback", "invariants", "requiredEvidence"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "objective": { "type": "string", "minLength": 1 },
    "feature": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "risk": { "enum": ["tier1", "tier2", "tier3"] },
    "approval": { "enum": ["required", "review", "autonomous"] },
    "commands": { "type": "array", "minItems": 1 },
    "projection": { "type": ["string", "null"] },
    "worker": { "type": "object", "required": ["bounded", "maxAttempts"] },
    "offline": { "type": "boolean" },
    "realtime": { "type": "boolean" },
    "conflictPolicy": { "type": "string", "minLength": 1 },
    "fallback": { "type": "string", "minLength": 1 },
    "invariants": { "type": "array", "minItems": 1 },
    "requiredEvidence": { "type": "array", "minItems": 1 }
  }
}
