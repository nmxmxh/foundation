# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy to .env and customize for your environment
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_ENV=development
SERVICE_NAME={{PROJECT_NAME}}
LOG_LEVEL=debug

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
# When unset, production defaults keep auth on and operational endpoints protected.
REQUIRE_AUTH=false
PROTECT_OPERATIONAL_ENDPOINTS=false

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
SERVER_PORT=8080
FRONTEND_PORT=3000

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# For production: Use DATABASE_URL
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# For development: Use individual variables
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME={{PROJECT_NAME}}_dev
DB_SSLMODE=disable
POSTGRES_VERSION=18
# Override when a project migration needs Postgres extensions not present in
# the default image, for example: TEST_POSTGRES_IMAGE=postgis/postgis:17-3.5
TEST_POSTGRES_IMAGE=

# Connection pool settings
DB_MAX_CONNS=0
DB_MIN_CONNS=2
DB_HEALTHCHECK_PERIOD_SECONDS=30
DB_CONNECT_TIMEOUT_SECONDS=10
DB_ACQUIRE_TIMEOUT=100ms
DB_QUERY_TIMEOUT=250ms
DB_HOT_READ_TIMEOUT=50ms
DB_SHARD_COUNT=1

# Hermes hotplane is mandatory but bounded. Oversized scopes fall back to
# Postgres instead of serving partial in-memory state.
HERMES_MAX_RECORDS_PER_SCOPE=10000
HERMES_MAX_BYTES_PER_SCOPE=16777216
HERMES_INDEXED_FIELDS=state,status,type,kind,bucket
# Projection scopes to eagerly warm from Postgres at startup so the projection
# gateway serves out-of-band (e.g. SQL-seeded) rows instead of "projection not
# found". Comma-separated "domain:collection:organization" triples.
# Example: HERMES_WARM_SCOPES=menu:dishes:org_1,menu:categories:org_1
HERMES_WARM_SCOPES=
# Fallback projection population: tail canonical projection envelopes from
# Redis Streams (hermes:projection:<domain>:<collection>:<organization>) for
# each warm scope. Canonical path is the RecordWorkerProcessor on the River
# queue; enable this for producers that cannot share the Postgres job queue.
HERMES_ENVELOPE_FALLBACK=false
# Shadow-mode snapshot rollout: with a directory set, every source rebuild
# diffs and refreshes a durable snapshot artifact (evidence counters in hermes
# runtime stats). Served warm path unchanged; empty disables.
HERMES_SNAPSHOT_DIR=

# -----------------------------------------------------------------------------
# Test Database Configuration
# -----------------------------------------------------------------------------
# make test-integration starts docker-compose.test.yml locally and exports these.
# CI should provide equivalent service containers and set TEST_DB_PORT=5432.
TEST_DB_HOST=localhost
TEST_DB_PORT=5433
TEST_DB_USER=postgres
TEST_DB_PASSWORD=postgres
TEST_DB_NAME={{PROJECT_NAME}}_test
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5433/{{PROJECT_NAME}}_test?sslmode=disable

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_PREFIX={{PROJECT_NAME}}
REDIS_SHARD_URLS=
REDIS_POOL_SIZE=32
REDIS_MIN_IDLE=4
REDIS_MAX_RETRIES=1
REDIS_DIAL_TIMEOUT=2s
REDIS_READ_TIMEOUT=500ms
REDIS_WRITE_TIMEOUT=500ms

# -----------------------------------------------------------------------------
# Test Redis Configuration
# -----------------------------------------------------------------------------
TEST_REDIS_HOST=localhost
TEST_REDIS_PORT=6380
TEST_REDIS_DB=0
TEST_REDIS_PASSWORD=
TEST_REDIS_URL=redis://localhost:6380/0
TEST_REDIS_PREFIX=test_{{PROJECT_NAME}}:
TEST_INFRA_REQUIRED=false
TEST_REDIS_REQUIRED=false

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
JWT_SECRET=change-this-to-a-secure-random-string-in-production
# Compatibility alias for projects that use a key-specific JWT setting.
JWT_SECRET_KEY=change-this-to-a-secure-random-string-in-production

# Signing keys (for document signing, webhooks, etc.)
SIGNING_KEY_ID=default-key-id
SIGNING_KEY_VERSION=v1

# Post-quantum posture
# Keep hot paths classical; prefer platform/edge hybrid TLS where available.
POST_QUANTUM_TLS_HYBRID_KEM=auto
POST_QUANTUM_SIGNATURE_ALGORITHM=classical
POST_QUANTUM_CRYPTO_INVENTORY_REQUIRED=true
POST_QUANTUM_LONG_LIVED_ARTIFACT_SIGNING=false

# -----------------------------------------------------------------------------
# Runtime Transport / WASM
# -----------------------------------------------------------------------------
RUNTIME_SHARED_MEMORY=auto
RUNTIME_TRANSPORT_ORDER=sab,transferable,postMessage,ws,http
RUNTIME_COMPRESSION=br,gzip,deflate,identity
RUNTIME_ARENA_BYTES=8388608
RUNTIME_REQUIRE_SHARED_WASM_MEMORY=false

# -----------------------------------------------------------------------------
# Realtime Projection Read Path (Hermes projection gateway)
# -----------------------------------------------------------------------------
# No dedicated URLs: the frontend derives the projection gateway endpoints from
# the app origin (or VITE_API_URL) plus the standard /v1/projections path, and
# upgrades http(s) -> ws(s) for the delta stream. A browser can only reach the
# public origin anyway, so same-origin derivation is the correct default. Set
# VITE_API_URL when the API is on a different origin than the page (typical in
# dev); production behind one reverse proxy needs nothing here.

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_WINDOW_SECONDS=60

# Dispatch/worker rate limiting
DISPATCH_MAX_CONCURRENT=64
DISPATCH_ACQUIRE_TIMEOUT_MS=200

# -----------------------------------------------------------------------------
# Tracing & Observability (Optional)
# -----------------------------------------------------------------------------
TRACING_ENABLED=false
TRACING_ENDPOINT=

# -----------------------------------------------------------------------------
# External Services (Customize as needed)
# -----------------------------------------------------------------------------
# Billing
BILLING_DISABLED=true
BILLING_ALLOW_MOCK=true
BILLING_PRIMARY_PROVIDER=

# PAYSTACK_PUBLIC_KEY=
# PAYSTACK_SECRET_KEY=
# PAYSTACK_WEBHOOK_SECRET=

# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Cloud Storage (e.g., Cloudflare R2, AWS S3)
# STORAGE_ENABLED=false
# STORAGE_ENDPOINT=
# STORAGE_BUCKET=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_PUBLIC_URL=

# Email Service
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com

# -----------------------------------------------------------------------------
# Queue Workers (Customize based on your workload)
# -----------------------------------------------------------------------------
QUEUE_WORKERS_DEFAULT=8

# -----------------------------------------------------------------------------
# Deployment Configuration
# -----------------------------------------------------------------------------
# For SSH-based deployments (make deploy)
DEPLOY_HOST=
DEPLOY_USER=
DEPLOY_PATH=/opt/{{PROJECT_NAME}}
DEPLOY_BACKUP_PATH=/opt/{{PROJECT_NAME}}-backups
DEPLOY_BRANCH=main

# Docker/Traefik network name
NETWORK_NAME=coolify

# SSL Certificate path (for managed databases)
SSL_CA_CERT_PATH=./config/certs/ca.crt

# -----------------------------------------------------------------------------
# Docker Build Cache
# -----------------------------------------------------------------------------
# Projects generated from foundation intentionally share this namespace so Go
# modules/build artifacts are downloaded once per Docker builder.
DOCKER_CACHE_NAMESPACE=ovasabi-foundation-v1
GO_VERSION=1.26
ALPINE_VERSION=3.23
MIGRATE_VERSION=v4.17.0
