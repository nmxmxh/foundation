# Git
.git
.gitignore
.gitattributes

# Documentation
*.md
!README.md
docs/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# Environment and secrets
.env
.env.*
!.env.example
*.pem
*.key

# Build artifacts
bin/
dist/
frontend/dist/
build/
coverage/
coverage.out
coverage.html
test-results/
.cache/
*.test
*.out

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db

# Test files
testdata/
*_test.go

# Docker files (avoid recursive build)
Dockerfile*
docker-compose*.yml
.dockerignore

# Node modules
**/node_modules/

# Vendor (if using vendoring, uncomment to exclude)
# vendor/

# Temporary files
tmp/
temp/
*.tmp

# Keep foundation packages in the context. Frontend Docker builds need local
# file dependencies under foundation/runtime-transport, foundation/frontend-kit,
# foundation/ui-minimal, config-contracts, and runtime-sdk browser-host.
