    "date-fns": "^4.1.0",
    "react-hook-form": "^7.54.0",
    "zod": "^3.24.0",
    "@hookform/resolvers": "^3.9.0",
    "@ovasabi/runtime-transport": "file:../foundation/runtime-transport/ts",
    "@ovasabi/frontend-kit": "file:../foundation/frontend-kit/ts",
