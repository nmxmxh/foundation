{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "{{PROJECT_NAME}}",
  "version": "0.1.0",
  "identifier": "{{PROJECT_IDENTIFIER}}",
  "build": {
    "beforeBuildCommand": "cd ../../frontend && npm run build",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "security": {
      "capabilities": ["main"],
      "csp": "default-src 'self' customprotocol: asset:; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self'; script-src 'self'; connect-src 'self'"
    },
    "windows": [
      {
        "title": "{{PROJECT_NAME}}",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
